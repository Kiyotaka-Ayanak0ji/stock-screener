# Copy to `.env` and fill in with your own Supabase project's values.
# All three vars are safe to ship in the browser bundle — RLS protects data.
# The service_role key is NEVER put here; it belongs only in edge function secrets.

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>
